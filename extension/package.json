{
  "name": "rustaria-extension",
  "version": "0.1.0",
  "description": "Browser extension for Rustaria download manager",
  "scripts": {
    "build": "esbuild background.ts content.ts --bundle --outdir=dist --format=esm",
    "watch": "esbuild background.ts content.ts --bundle --outdir=dist --format=esm --watch",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.260",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0"
  }
}
